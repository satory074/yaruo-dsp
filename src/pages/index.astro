---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import ChapterCard from "../components/ChapterCard.astro";
import Avatar from "../components/dialog/Avatar.astro";

const chapters = (await getCollection("chapters")).sort((a, b) => a.data.order - b.data.order);
const main = chapters.filter((c) => c.data.order < 90);
const appendix = chapters.filter((c) => c.data.order >= 90);
const demoTotal = chapters.reduce((acc, c) => acc + c.data.demos.length, 0);
---

<Layout
  title="やる夫で学ぶディジタル信号処理"
  description="フーリエ級数からディジタルフィルタ設計まで、やる夫とやらない夫の対話とインタラクティブなデモで学ぶディジタル信号処理の入門教材。"
>
  <section class="hero">
    <div class="flex items-end gap-4">
      <div class="flex -space-x-1">
        <Avatar character="yaruo" mood="smile" size={64} />
        <Avatar character="yaranaio" mood="normal" size={64} />
      </div>
      <p class="hero-eyebrow pb-2">
        DIGITAL SIGNAL PROCESSING<br />— WITH YARUO &amp; YARANAIO —
      </p>
    </div>
    <h1>
      やる夫で学ぶ<br />
      <span class="hero-em">ディジタル信号処理</span>
    </h1>
    <p class="hero-lead">
      フーリエ級数からディジタルフィルタの設計まで。
      数式を恐れるやる夫と、容赦なく数式を出してくるやらない夫の対話に、
      スライダーで動かせる{demoTotal}個のインタラクティブデモを添えて、
      「式が何をしているのか」を目で確かめながら進む信号処理の入門教材。
    </p>
    <div class="hero-ticks" aria-hidden="true"></div>
  </section>

  <section>
    <h2 class="mb-5 border-l-4 border-(--color-vermilion) pl-3 text-xl">目次</h2>
    <div class="grid gap-3">
      {main.map((entry) => <ChapterCard entry={entry} />)}
    </div>
    {
      appendix.length > 0 && (
        <>
          <h2 class="mt-10 mb-5 border-l-4 border-(--color-indigo) pl-3 text-xl">付録</h2>
          <div class="grid gap-3">
            {appendix.map((entry) => (
              <ChapterCard entry={entry} />
            ))}
          </div>
        </>
      )
    }
  </section>

  <script>
    // 読了済みの章カードに ✓ を付ける（プログレッシブエンハンスメント）
    try {
      const read = new Set<string>(JSON.parse(localStorage.getItem("yaruo-dsp:read") ?? "[]"));
      document.querySelectorAll<HTMLElement>(".chapter-card[data-slug]").forEach((card) => {
        if (read.has(card.dataset.slug ?? "")) card.classList.add("is-read");
      });
    } catch {
      /* noop */
    }
  </script>
</Layout>
