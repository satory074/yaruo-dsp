---
import type { CollectionEntry } from "astro:content";

interface Props {
  prev: CollectionEntry<"chapters"> | null;
  next: CollectionEntry<"chapters"> | null;
}

const { prev, next } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<nav class="chapter-nav" aria-label="前後の章">
  {
    prev && (
      <a href={`${base}/${prev.id}/`} class="nav-prev">
        <div class="nav-dir">← PREV</div>
        <div class="nav-title">
          {prev.data.chapterLabel} {prev.data.title}
        </div>
      </a>
    )
  }
  {
    next && (
      <a href={`${base}/${next.id}/`} class="nav-next">
        <div class="nav-dir">NEXT →</div>
        <div class="nav-title">
          {next.data.chapterLabel} {next.data.title}
        </div>
      </a>
    )
  }
</nav>
